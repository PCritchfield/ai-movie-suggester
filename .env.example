# =============================================================================
# ai-movie-suggester configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- Required ---

# Your Jellyfin server URL (include http:// or https://)
# Use the internal Docker network name if running in the same compose stack
# Example: http://jellyfin:8096  or  http://192.168.1.100:8096
JELLYFIN_URL=

# Secret key for signing session cookies (generate with: openssl rand -hex 32)
# WARNING: Rotating this value invalidates all active sessions.
# Users will need to log in again.
SESSION_SECRET=

# --- Ollama ---

# Ollama endpoint — leave as default if using the bundled Ollama sidecar
# Change this if you already run Ollama elsewhere
OLLAMA_HOST=http://ollama:11434

# Model for chat/recommendations (must be pulled on your Ollama instance)
OLLAMA_CHAT_MODEL=llama3.1:8b

# Model for generating embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text

# Timeout in seconds for embedding requests (default: 120)
# Embedding calls can be slow during model cold-load or CPU inference
# OLLAMA_EMBED_TIMEOUT=120

# Timeout in seconds for Ollama health/ping checks (default: 5)
# OLLAMA_HEALTH_TIMEOUT=5

# --- Optional: TMDb Metadata Enrichment ---

# TMDb is OFF by default (privacy-first). Enable to enrich movie metadata
# with additional descriptions, keywords, and cast info from TMDb.
# When enabled, search queries and your server's IP are sent to api.themoviedb.org
TMDB_ENABLED=false

# TMDb API key — get one free at https://www.themoviedb.org/settings/api
# Only needed if TMDB_ENABLED=true
TMDB_API_KEY=

# --- Library (Vector DB) ---

# Path to the library SQLite database (stores embeddings + item metadata)
# LIBRARY_DB_PATH=data/library.db

# Embedding dimensions (must match the chosen OLLAMA_EMBED_MODEL output)
# OLLAMA_EMBED_DIMENSIONS=768

# --- Sessions ---

# Secure cookie flag — controls the Secure attribute on session cookies.
# Must be true in production (HTTPS). Set to false for local HTTP development.
# SESSION_SECURE_COOKIE=true

# Maximum concurrent sessions per Jellyfin user (oldest evicted on overflow)
# MAX_SESSIONS_PER_USER=5

# Path to the session SQLite database file
# SESSION_DB_PATH=data/sessions.db

# Login rate limit per IP address (slowapi format)
# LOGIN_RATE_LIMIT=5/minute

# Trusted reverse proxy IPs for X-Forwarded-For extraction
# TRUSTED_PROXY_IPS=127.0.0.1

# --- Permissions ---

# How long to cache a user's permitted item IDs (in seconds, default: 300)
# Lower values mean more Jellyfin API calls but fresher permissions
# PERMISSION_CACHE_TTL_SECONDS=300

# --- Security ---

# Allowed origin for CORS (the URL where the frontend is served)
# Default: http://localhost:3000 (matches the dev frontend port)
# CORS_ORIGIN=http://localhost:3000

# Enable /docs and /redoc API documentation endpoints
# Default: enabled when LOG_LEVEL=debug, disabled otherwise
# Set explicitly to override the LOG_LEVEL default
# ENABLE_DOCS=

# --- Advanced ---

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Session expiry in hours (forces re-authentication with Jellyfin)
SESSION_EXPIRY_HOURS=24

# Rate limit for chat endpoint (requests per minute per user)
CHAT_RATE_LIMIT=10

# Rate limit for search endpoint (requests per minute per user)
SEARCH_RATE_LIMIT=10

# How many extra candidates to fetch from vector search to compensate for permission filtering (1–10)
# SEARCH_OVERFETCH_MULTIPLIER=3

# Timeout for Jellyfin API requests in seconds (default: 10)
JELLYFIN_TIMEOUT=10.0

# --- Library Sync ---

# Jellyfin API key for background library sync (optional).
# Enables automatic sync without requiring a logged-in user session.
# Generate in Jellyfin: Dashboard > API Keys > Add.
# SECURITY WARNING: Treat this like a root password — it grants full
# access to your Jellyfin server. Never commit to version control.
# If not set, library sync is triggered only via user session tokens.
# JELLYFIN_API_KEY=

# Path to the library metadata SQLite database file
# LIBRARY_DB_PATH=data/library.db

# Page size for Jellyfin library sync pagination
# LIBRARY_SYNC_PAGE_SIZE=200

# --- Sync Engine ---

# Jellyfin admin user ID (find in Jellyfin Dashboard > Users > click user > copy ID from URL)
# Required for scheduled background sync
# JELLYFIN_ADMIN_USER_ID=

# How often to run automatic library sync (in hours, default: 6)
# SYNC_INTERVAL_HOURS=6

# Days to keep soft-deleted items before permanent removal (default: 7)
# TOMBSTONE_TTL_DAYS=7

# WAL checkpoint threshold in MB (default: 50)
# WAL_CHECKPOINT_THRESHOLD_MB=50

# --- Embedding Worker ---

# Number of items to embed per worker cycle (1–50, default: 10)
# EMBEDDING_BATCH_SIZE=10

# Seconds between embedding worker cycles (default: 300)
# EMBEDDING_WORKER_INTERVAL_SECONDS=300

# Maximum retries before marking an item as permanently failed (default: 3)
# EMBEDDING_MAX_RETRIES=3

# Seconds to wait before retrying a failed embedding (default: 300)
# EMBEDDING_COOLDOWN_SECONDS=300

# --- Local Development ---
# For local HTTP development only, uncomment the line below.
# WARNING: This MUST remain commented out (or set to true) for any
# internet-facing deployment. Insecure cookies are transmitted over HTTP.
# SESSION_SECURE_COOKIE=false
