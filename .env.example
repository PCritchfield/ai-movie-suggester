# =============================================================================
# ai-movie-suggester configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- Required ---

# Your Jellyfin server URL (include http:// or https://)
# Use the internal Docker network name if running in the same compose stack
# Example: http://jellyfin:8096  or  http://192.168.1.100:8096
JELLYFIN_URL=

# Secret key for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=

# --- Ollama ---

# Ollama endpoint — leave as default if using the bundled Ollama sidecar
# Change this if you already run Ollama elsewhere
OLLAMA_HOST=http://ollama:11434

# Model for chat/recommendations (must be pulled on your Ollama instance)
OLLAMA_CHAT_MODEL=llama3.1:8b

# Model for generating embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Optional: TMDb Metadata Enrichment ---

# TMDb is OFF by default (privacy-first). Enable to enrich movie metadata
# with additional descriptions, keywords, and cast info from TMDb.
# When enabled, search queries and your server's IP are sent to api.themoviedb.org
TMDB_ENABLED=false

# TMDb API key — get one free at https://www.themoviedb.org/settings/api
# Only needed if TMDB_ENABLED=true
TMDB_API_KEY=

# --- Advanced ---

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Session expiry in hours (forces re-authentication with Jellyfin)
SESSION_EXPIRY_HOURS=24

# Rate limit for chat endpoint (requests per minute per user)
CHAT_RATE_LIMIT=10
