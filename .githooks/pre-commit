#!/bin/sh
set -e
# Pre-commit hook for ai-movie-suggester monorepo
# Install with: make hooks
# Runs ruff on staged Python files, eslint+prettier on staged TS/TSX files
# Deliberately fast — no tests or type-checking (that's CI's job)

# Backend: ruff on staged Python files
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^backend/.*\.py$' || true)
if [ -n "$PYTHON_FILES" ]; then
  echo "🐍 Running ruff on backend..."
  # Strip backend/ prefix — ruff runs from the backend directory
  BACKEND_REL=$(echo "$PYTHON_FILES" | sed 's|^backend/||')
  cd backend
  echo "$BACKEND_REL" | tr '\n' '\0' | xargs -0 uv run ruff check --fix
  echo "$BACKEND_REL" | tr '\n' '\0' | xargs -0 uv run ruff format
  cd ..
  echo "$PYTHON_FILES" | tr '\n' '\0' | xargs -0 git add
fi

# Frontend: eslint + prettier on staged TS/TSX files
TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^frontend/.*\.\(ts\|tsx\)$' || true)
if [ -n "$TS_FILES" ]; then
  echo "📦 Running eslint + prettier on frontend..."
  # Strip frontend/ prefix — tools run from the frontend directory
  FRONTEND_REL=$(echo "$TS_FILES" | sed 's|^frontend/||')
  cd frontend
  echo "$FRONTEND_REL" | tr '\n' '\0' | xargs -0 npx eslint --fix
  echo "$FRONTEND_REL" | tr '\n' '\0' | xargs -0 npx prettier --write
  cd ..
  echo "$TS_FILES" | tr '\n' '\0' | xargs -0 git add
fi
